rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isCommentAuthor() {
      return isSignedIn() && resource.data.autorId == request.auth.uid;
    }

    match /perguntas/{modo}/itens/{questionId} {
      allow read: if true;
      allow write: if isSignedIn();

      match /comentarios/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.autorId == request.auth.uid
          && request.resource.data.texto is string
          && request.resource.data.texto.size() >= 3
          && request.resource.data.texto.size() <= 220;
        allow update: if isSignedIn();
        allow delete: if isCommentAuthor();

        match /likes/{uid} {
          allow read: if isSignedIn();
          allow create, delete: if isSignedIn() && request.auth.uid == uid;
          allow update: if false;
        }
      }
    }

    match /users/{uid}/favoritos/{favoriteId} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /comunidade_favoritas/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /sugestoes/{suggestionId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    match /config/feature_flags {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
